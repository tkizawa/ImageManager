<Window x:Class="ImageManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageManager"
        xmlns:viewmodels="clr-namespace:ImageManager.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        Title="Image Manager" Height="600" Width="900"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="フォルダを開く..." Command="{Binding SelectFolderCommand}" Padding="10,5" />
            <TextBlock Text="{Binding CurrentFolderPath}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold" />
        </StackPanel>

        <!-- Thumbnail Grid -->
        <ListBox Grid.Row="1" Grid.Column="0" 
                 ItemsSource="{Binding Images}" 
                 SelectedItem="{Binding SelectedImage}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5" Width="120">
                        <!-- Setting DecodePixelWidth is important for performance on large images, but here we just bind to FilePath and rely on WPF's default decoding. For a real app we need an IValueConverter to load thumbnails efficiently. -->
                        <Image Source="{Binding FilePath}" Width="100" Height="100" Stretch="Uniform" />
                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FileName}" TextAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" />

        <!-- Preview and Properties -->
        <Border Grid.Row="1" Grid.Column="2" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Padding="10">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="プレビュー" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                    <Image Source="{Binding SelectedImage.FilePath}" MaxHeight="300" Stretch="Uniform" Margin="0,0,0,20" />
                    
                    <TextBlock Text="プロパティ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ファイル名:" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedImage.FileName}" TextWrapping="Wrap" Margin="0,0,0,5" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="サイズ (Bytes):" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedImage.FileSize}" Margin="0,0,0,5" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="作成日時:" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedImage.CreationTime, StringFormat='yyyy/MM/dd HH:mm:ss'}" Margin="0,0,0,5" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
