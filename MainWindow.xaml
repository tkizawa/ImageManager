<Window x:Class="ImageManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:ImageManager"
        xmlns:viewmodels="using:ImageManager.ViewModels"
        xmlns:controls="using:CommunityToolkit.WinUI.Controls"
        mc:Ignorable="d">
    <Grid Margin="10" x:Name="RootGrid" Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Top Bar -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="フォルダを開く..." Command="{Binding SelectFolderCommand}" Padding="10,5" />
            <TextBlock Text="{Binding CurrentFolderPath}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold" />
        </StackPanel>

        <!-- Left Pane (Tabs) -->
        <TabView Grid.Row="1" Grid.Column="0" IsAddTabButtonVisible="False" TabWidthMode="SizeToContent" Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
            <!-- フォルダタブ (ツリー) -->
            <TabViewItem Header="フォルダ" IsClosable="False">
                <TreeView x:Name="FolderTreeView"
                          ItemsSource="{Binding Folders}"
                          ItemInvoked="FolderTreeView_ItemInvoked">
                    <TreeView.ItemTemplate>
                        <DataTemplate>
                            <TreeViewItem ItemsSource="{Binding Children}" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                <TextBlock Text="{Binding Name}">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="お気に入りに追加" 
                                                            Click="AddFavoriteFolder_Click" 
                                                            Tag="{Binding}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                </TextBlock>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabViewItem>

            <!-- お気に入りタブ -->
            <TabViewItem Header="お気に入り" IsClosable="False">
                <ListView ItemsSource="{Binding FavoriteFolders}" 
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="FavoriteListView_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,5" ToolTipService.ToolTip="{Binding}">
                                <TextBlock Text="{Binding Converter={StaticResource PathToFolderNameConverter}}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="開く" 
                                                            Click="OpenFavoriteFolder_Click" 
                                                            Tag="{Binding}" />
                                            <MenuFlyoutItem Text="お気に入りから削除" 
                                                            Click="RemoveFavoriteFolder_Click" 
                                                            Tag="{Binding}" />
                                        </MenuFlyout>
                                    </TextBlock.ContextFlyout>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabViewItem>
        </TabView>

        <!-- Splitter 1 -->
        <Thumb Grid.Row="1" Grid.Column="1" Width="11" x:Name="TreeSplitter" Background="Transparent" DragDelta="TreeSplitter_DragDelta" Loaded="Splitter_Loaded" />

        <!-- Thumbnail Grid -->
        <GridView Grid.Row="1" Grid.Column="2" x:Name="ThumbnailGridView"
                  ItemsSource="{Binding Images}" 
                  SelectedItem="{Binding SelectedImage, Mode=TwoWay}"
                  DoubleTapped="ThumbnailGridView_DoubleTapped"
                  Background="White" BorderBrush="#DDDDDD" BorderThickness="1">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5" Width="{Binding DataContext.ThumbnailPanelWidth, ElementName=RootGrid}">
                        <StackPanel.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Windowsのフォトで画像を開く" Click="OpenWithPhotos_Click" Tag="{Binding}" />
                                <MenuFlyoutItem Text="エクスプローラーで表示" Click="ShowInExplorer_Click" Tag="{Binding}" />
                            </MenuFlyout>
                        </StackPanel.ContextFlyout>
                        <Image Source="{Binding FilePath, Converter={StaticResource StringToImageSourceConverter}}" 
                               Width="{Binding DataContext.ThumbnailSize, ElementName=RootGrid}" 
                               Height="{Binding DataContext.ThumbnailSize, ElementName=RootGrid}" 
                               Stretch="Uniform" />
                        <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding FileName}" TextAlignment="Center" Margin="0,5,0,0" />
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        
        <!-- Splitter 2 -->
        <Thumb Grid.Row="1" Grid.Column="3" Width="11" x:Name="PreviewSplitter" Background="Transparent" DragDelta="PreviewSplitter_DragDelta" Loaded="Splitter_Loaded" />

        <!-- Preview and Properties -->
        <Border Grid.Row="1" Grid.Column="4" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Padding="10">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="プレビュー" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                    <Image Source="{Binding SelectedImage.FilePath, Converter={StaticResource StringToImageSourceConverter}}" MaxHeight="300" Stretch="Uniform" Margin="0,0,0,20" />
                    
                    <TextBlock Text="プロパティ" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ファイル名:" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedImage.FileName}" TextWrapping="Wrap" Margin="0,0,0,5" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="サイズ (Bytes):" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedImage.FileSize}" Margin="0,0,0,5" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="ファイル作成日時:" FontWeight="SemiBold" Margin="0,0,10,5" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedImage.CreationTime}" Margin="0,0,0,5" />
                        
                        <!-- EXIF Info -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="撮影日:" FontWeight="SemiBold" Margin="0,10,10,5" Visibility="{Binding SelectedImage.DateTaken, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedImage.DateTaken}" Margin="0,10,0,5" Visibility="{Binding SelectedImage.DateTaken, Converter={StaticResource StringToVisibilityConverter}}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="カメラ:" FontWeight="SemiBold" Margin="0,0,10,5" Visibility="{Binding SelectedImage.CameraModel, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedImage.CameraModel}" Margin="0,0,0,5" Visibility="{Binding SelectedImage.CameraModel, Converter={StaticResource StringToVisibilityConverter}}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="レンズ:" FontWeight="SemiBold" Margin="0,0,10,5" Visibility="{Binding SelectedImage.Lens, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedImage.Lens}" Margin="0,0,0,5" Visibility="{Binding SelectedImage.Lens, Converter={StaticResource StringToVisibilityConverter}}" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="F値:" FontWeight="SemiBold" Margin="0,0,10,5" Visibility="{Binding SelectedImage.FNumber, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedImage.FNumber}" Margin="0,0,0,5" Visibility="{Binding SelectedImage.FNumber, Converter={StaticResource StringToVisibilityConverter}}" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="露出時間:" FontWeight="SemiBold" Margin="0,0,10,5" Visibility="{Binding SelectedImage.ExposureTime, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedImage.ExposureTime}" Margin="0,0,0,5" Visibility="{Binding SelectedImage.ExposureTime, Converter={StaticResource StringToVisibilityConverter}}" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="ISO:" FontWeight="SemiBold" Margin="0,0,10,5" Visibility="{Binding SelectedImage.IsoSpeed, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedImage.IsoSpeed}" Margin="0,0,0,5" Visibility="{Binding SelectedImage.IsoSpeed, Converter={StaticResource StringToVisibilityConverter}}" />
                        
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="焦点距離:" FontWeight="SemiBold" Margin="0,0,10,5" Visibility="{Binding SelectedImage.FocalLength, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedImage.FocalLength}" Margin="0,0,0,5" Visibility="{Binding SelectedImage.FocalLength, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
